# Postgres connection string (Railway Postgres service or local docker-compose)
DATABASE_URL=postgresql://aios:aios@localhost:5433/aios

# Provider order: try left-to-right, fall back on error
LLM_PROVIDER=groq,gemini

# Groq (primary — free tier, multiple models chained for resilience)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Auth — single user
AUTH_PASSWORD=change-me
# Random long string used to sign the session cookie
AUTH_SECRET=change-me-too

# ── Optional: read-only connections to your OTHER apps' databases ──────────
# Ask each app's developer for a dedicated READ-ONLY Postgres user (not the
# primary admin URL). Leave unset to skip — everything degrades gracefully.
BLAZERENT_DATABASE_URL=
FINLY_DATABASE_URL=
BIKA_DATABASE_URL=
